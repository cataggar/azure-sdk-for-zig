// Component world for `codegen-cli`.
//
// IMPORTANT: imports here are limited to the subset of wasi:cli /
// wasi:io / wasi:filesystem / etc. that:
//
//   1. tcgc.wasm (the provider) actually imports, AND
//   2. wabt's bundled `adapters/wasi-preview1/wit/deps/` ships a
//      WIT definition for.
//
// Today (May 2026) #2 is the binding constraint — wabt's deps tree
// is a *trimmed slice* of wasi:cli@0.2.6 covering only what the
// preview1 adapter needs (stdout + stderr + some clocks + a partial
// filesystem). Trying to import `wasi:cli/stdin@0.2.6` or
// `wasi:http/types@0.2.6` produces `UnknownInterface` /
// `UnexpectedToken` from `wabt component embed`. Tracked at
// cataggar/wabt#216.
//
// Once #216 lands and wabt's deps tree is a complete wasi 0.2.6
// set, expand this world to mirror everything tcgc.wasm imports
// (see `eng/codegen/tcgc-component/dist/tcgc.wasm` for the full
// list under `jco wit`).
//
// `wabt component compose --align-wasi=0.2.6` rewrites tcgc.wasm's
// 0.2.10 references down to 0.2.6 at compose time.

package azure:codegen-cli@0.1.0;

world cli {
    import wasi:cli/exit@0.2.6;
    import wasi:cli/stdout@0.2.6;
    import wasi:cli/stderr@0.2.6;
    import wasi:io/error@0.2.6;
    import wasi:io/streams@0.2.6;
    import wasi:clocks/wall-clock@0.2.6;
    import wasi:clocks/monotonic-clock@0.2.6;
    import wasi:filesystem/preopens@0.2.6;
    import wasi:filesystem/types@0.2.6;
    import wasi:random/random@0.2.6;

    import azure:codegen/tcgc;

    export wasi:cli/run@0.2.6;
}
